# Copy to .env.production (or .env.local for dev) and fill in your values.
# Values prefixed with NEXT_PUBLIC_ are baked into the client bundle at build
# time. Rebuild with `./deploy.sh` after changing them.

# ── Runtime ──────────────────────────────────────────────────────────
PORT=3100
HOSTNAME=127.0.0.1
NODE_ENV=production

# ── App-level public URLs (REQUIRED at build time) ──────────────────
# Base URL of the Frappe / ERPNext backend this storefront fetches data from.
NEXT_PUBLIC_ERP_URL=https://erp.example.com

# The canonical URL of the storefront itself. Used for SEO metadata,
# OpenGraph canonical links, and sitemap entries.
NEXT_PUBLIC_STOREFRONT_URL=https://www.example.com

# ── Observability ────────────────────────────────────────────────────
# Sentry DSN (optional — omit to disable error reporting)
SENTRY_DSN=

# ── Server-only secrets (DO NOT prefix with NEXT_PUBLIC_) ────────────
# Basic-auth credentials for product-feed endpoints (/api/feeds/*).
FEED_USERNAME=
FEED_PASSWORD=
FEED_TOKEN=

# HMAC key used to verify incoming Google Ads webhook leads.
GOOGLE_ADS_WEBHOOK_KEY=
